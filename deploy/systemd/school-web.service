[Unit]
Description=ИНТЕГРАЛ — school website (FastAPI)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/school-system/web
EnvironmentFile=/opt/school-system/.env
ExecStart=/opt/school-system/web/venv/bin/uvicorn server:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=school-web

NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
